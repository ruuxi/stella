# TypeScript incremental build artifacts (machine-generated; never commit).
*.tsbuildinfo

# Exec worker fallback CJS cache (Node-test runtime only; Bun loads .ts directly).
runtime/kernel/exec/.exec-worker-cache/

# Stella runtime state (mutable, user-specific, never commit).
# Seed content under state/ stays tracked via the allowlist below.
state/*
state/electron-user-data/
!state/DREAM.md
!state/registry.md
!state/skills/
state/stella-computer/sessions/
state/skills/user-profile/
!state/notes/
state/notes/*
!state/notes/README.md
!state/outputs/
state/outputs/*
!state/outputs/README.md
state/core-memory.md
state/raw/

.env.local
