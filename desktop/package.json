{
  "name": "Stella",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:electron": "vitest run --config vitest.electron.config.ts",
    "preview": "vite preview",
    "native:build": "cd native && npm install && npm run build",
    "electron:dev": "concurrently \"cross-env NODE_ENV=development vite\" \"cd ../shared && npx tsc && cd ../frontend && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && wait-on file:.vite-dev-url && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run native:build && cd ../shared && npx tsc && cd ../frontend && tsc -b && vite build && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && electron-builder",
    "electron:preview": "cd ../shared && npx tsc && cd ../frontend && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && electron .",
    "emotes:sync": "node scripts/fetch-emotes.mjs",
    "emotes:sync:clean": "node scripts/fetch-emotes.mjs --clean",
    "emotes:label": "node scripts/label-emotes.mjs",
    "emotes:label:dry": "node scripts/label-emotes.mjs --dry-run",
    "emotes:emoji-index": "node scripts/build-emote-emoji-index.mjs",
    "emotes:prune-family": "node scripts/prune-emotes-by-emoji-family.mjs",
    "emotes:optimize": "node scripts/optimize-emotes.mjs",
    "postinstall": "electron-rebuild --build-from-source -o better-sqlite3"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.69",
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/openai": "^3.0.37",
    "@ai-sdk/provider-utils": "^4.0.15",
    "@convex-dev/better-auth": "^0.10.0",
    "@gitlab/gitlab-ai-provider": "^3.6.0",
    "@google/genai": "^1.43.0",
    "@hookform/resolvers": "^5.2.2",
    "@mariozechner/pi-agent-core": "0.55.3",
    "@mariozechner/pi-ai": "0.55.3",
    "@mariozechner/pi-coding-agent": "0.55.3",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sinclair/typebox": "0.34.41",
    "@stella/shared": "file:../shared",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-virtual": "^3.13.18",
    "ai": "^6.0.97",
    "better-auth": "1.4.9",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "hera-browser": "^0.0.57",
    "input-otp": "^1.4.2",
    "livekit-client": "^2.0.0",
    "lucide-react": "^0.563.0",
    "marked": "^17.0.1",
    "marked-shiki": "^1.2.1",
    "motion": "^12.35.0",
    "naudiodon2": "^2.5.0",
    "next-themes": "^0.4.6",
    "onnxruntime-node": "^1.24.2",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "recharts": "2.15.4",
    "shiki": "^3.21.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "uiohook-napi": "^1.5.4",
    "vaul": "^1.1.2",
    "ws": "^8.19.0",
    "yaml": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.13.5",
    "cross-spawn": "^7.0.6",
    "qs": "^6.15.0",
    "tar": "^7.5.9"
  },
  "build": {
    "appId": "com.stella.app",
    "productName": "Stella",
    "protocols": {
      "name": "Stella Auth",
      "schemes": ["Stella"]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "native",
        "to": "native",
        "filter": [
          "mouse_block.exe",
          "window_info.exe",
          "audio_ducking.exe",
          "window_info",
          "audio_ducking"
        ]
      },
      {
        "from": "resources/bundled-skills",
        "to": "bundled-skills",
        "filter": ["**/*"]
      },
      {
        "from": "resources/bundled-commands",
        "to": "bundled-commands",
        "filter": ["**/*"]
      },
      {
        "from": "resources/models",
        "to": "models",
        "filter": ["*.onnx"]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
