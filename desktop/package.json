{
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "games:bindings": "node scripts/generate-game-bindings.mjs",
    "dev": "node scripts/generate-game-bindings.mjs && vite",
    "build": "node scripts/generate-game-bindings.mjs && bunx --package typescript@5.9.3 tsc --build && vite build",
    "format": "bunx prettier@3.6.2 --write .",
    "format:check": "bunx prettier@3.6.2 --check .",
    "lint": "node scripts/generate-game-bindings.mjs && eslint .",
    "test": "node scripts/generate-game-bindings.mjs && vitest",
    "test:run": "node scripts/generate-game-bindings.mjs && vitest run",
    "test:electron": "node scripts/generate-game-bindings.mjs && vitest run --config vitest.electron.config.ts",
    "test:stella-browser": "vitest run --config stella-browser/vitest.config.ts",
    "preview": "vite preview",
    "native:build": "cd native && npm install && npm run build",
    "workspace:create-app": "node scripts/create-workspace-app.mjs",
    "electron:dev": "node scripts/generate-game-bindings.mjs && node scripts/electron-dev-runner.mjs",
    "electron:typecheck": "bunx --package typescript@5.9.3 tsc -p tsconfig.electron.json --pretty false --noEmit && bunx --package typescript@5.9.3 tsc -p tsconfig.preload.json --pretty false --noEmit",
    "electron:typecheck:watch": "concurrently -k --kill-others-on-fail \"bunx --package typescript@5.9.3 tsc -w -p tsconfig.electron.json --preserveWatchOutput --noEmit\" \"bunx --package typescript@5.9.3 tsc -w -p tsconfig.preload.json --preserveWatchOutput --noEmit\"",
    "electron:build": "node scripts/generate-game-bindings.mjs && npm run native:build && bunx --package typescript@5.9.3 tsc --build && vite build && bunx --package typescript@5.9.3 tsc -p tsconfig.electron.json && bunx --package typescript@5.9.3 tsc -p tsconfig.preload.json && electron-builder",
    "electron:preview": "node scripts/generate-game-bindings.mjs && bunx --package typescript@5.9.3 tsc -p tsconfig.electron.json && bunx --package typescript@5.9.3 tsc -p tsconfig.preload.json && electron .",
    "emotes:sync": "node scripts/fetch-emotes.mjs",
    "emotes:sync:clean": "node scripts/fetch-emotes.mjs --clean",
    "emotes:label": "node scripts/label-emotes.mjs",
    "emotes:label:dry": "node scripts/label-emotes.mjs --dry-run",
    "emotes:emoji-index": "node scripts/build-emote-emoji-index.mjs",
    "emotes:prune-family": "node scripts/prune-emotes-by-emoji-family.mjs",
    "emotes:optimize": "node scripts/optimize-emotes.mjs",
    "postinstall": "npx @electron/rebuild -o better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1004.0",
    "@convex-dev/better-auth": "^0.10.0",
    "@google/genai": "^1.44.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sinclair/typebox": "0.34.41",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@tailwindcss/vite": "^4.1.18",
    "ai": "^6.0.116",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-auth": "1.4.9",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "cloudflared": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.33.1",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "dugite": "3.2.1",
    "effect": "^4.0.0-beta.28",
    "hera-browser": "^0.0.57",
    "lucide-react": "^0.563.0",
    "marked": "^17.0.1",
    "morphdom": "^2.7.8",
    "motion": "^12.35.0",
    "next-themes": "^0.4.6",
    "onnxruntime-node": "^1.24.2",
    "openai": "6.10.0",
    "partial-json": "^0.1.7",
    "proxy-agent": "^6.5.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "recharts": "2.15.4",
    "shiki": "^3.21.0",
    "sonner": "^2.0.7",
    "spacetimedb": "^2.0.4",
    "streamdown": "^2.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "uiohook-napi": "^1.5.4",
    "undici": "^7.19.1",
    "vaul": "^1.1.2",
    "ws": "^8.19.0",
    "yaml": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/morphdom": "^2.4.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.0",
    "bun-types": "^1.3.11",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.0.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.13.5",
    "cross-spawn": "^7.0.6",
    "qs": "^6.15.0",
    "tar": "^7.5.9"
  },
  "build": {
    "appId": "com.stella.app",
    "productName": "Stella",
    "protocols": {
      "name": "Stella Auth",
      "schemes": [
        "Stella"
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "native/out",
        "to": "native/out",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/stella-defaults/core-skills",
        "to": "stella-defaults/core-skills",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/stella-defaults/extensions",
        "to": "stella-defaults/extensions",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/bundled-commands",
        "to": "bundled-commands",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/models",
        "to": "models",
        "filter": [
          "*.onnx"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
