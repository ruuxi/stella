{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist-electron",
    "rootDir": "..",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "bun-types"],
    "composite": true,
  },
  "include": [
    "electron/**/*",
    "../runtime/**/*",
    "src/shared/contracts/**/*",
    "src/shared/ai/**/*",
    "src/shared/lib/convex-urls.ts",
    "src/shared/lib/mini-double-tap.ts",
    "src/shared/lib/radial-trigger.ts",
    "src/shared/stella-api.ts",
    "src/convex/api.ts"
  ],
  "exclude": ["electron/preload.ts", "**/*.test.ts"],
}
