{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@stella/stella-ai": ["./packages/stella-ai/src/index.ts"],
      "@stella/stella-agent-core": ["./packages/stella-agent-core/src/index.ts"],
      "@stella/stella-runtime": ["./packages/stella-runtime/src/index.ts"],
      "@stella/stella-runtime/*": ["./packages/stella-runtime/src/*"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "declaration": true,
    "declarationMap": false,
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.test.ts", "dist"]
}
