{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist-electron",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "emitDeclarationOnly": false
  },
  "include": [
    "electron/preload.ts",
    "../runtime/contracts/**/*",
    "../runtime/protocol/**/*",
    "src/shared/contracts/**/*"
  ]
}
