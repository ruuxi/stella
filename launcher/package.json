{
	"name": "stella-launcher",
	"version": "0.0.1",
	"description": "Stella desktop launcher — install, update, and manage the Stella runtime",
	"scripts": {
		"electrobun:prepare": "node scripts/ensure-electrobun-rcedit.cjs",
		"start": "vite build && bun run electrobun:prepare && electrobun dev",
		"dev": "bun run electrobun:prepare && electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && bun run electrobun:prepare && electrobun build --env=canary"
	},
	"dependencies": {
		"electrobun": "1.15.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
