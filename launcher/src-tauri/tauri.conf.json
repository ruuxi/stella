{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-capability-schema/main/schema.json",
  "productName": "Stella",
  "version": "0.0.1",
  "identifier": "com.stella.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev:frontend",
    "beforeBuildCommand": "bun run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Stella",
        "width": 420,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "11.0",
      "dmg": {
        "background": "./dmg/background@1x.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 210
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 210
        }
      }
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
