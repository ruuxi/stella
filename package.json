{
  "name": "stella",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "desktop/dist-electron/desktop/electron/main.js",
  "scripts": {
    "dev": "cd desktop && vite",
    "preview": "cd desktop && vite preview",
    "build": "bun run routes:generate && cd desktop && tsgo --build && vite build",
    "format": "bunx prettier@3.6.2 --write .",
    "format:check": "bunx prettier@3.6.2 --check .",
    "lint": "cd desktop && eslint .",
    "test": "cd desktop && vitest",
    "test:run": "cd desktop && vitest run",
    "test:electron": "cd desktop && vitest run --config vitest.electron.config.ts",
    "test:stella-browser": "cd desktop && vitest run --config stella-browser/vitest.config.ts",
    "routes:generate": "cd desktop && bunx --package @tanstack/router-cli@1.166.40 tsr generate",
    "reset": "cd desktop && node scripts/reset-dev.mjs",
    "reset:all": "cd desktop && node scripts/reset-dev.mjs --with-permissions",
    "reset:sql": "cd desktop && node scripts/reset-sql.mjs",
    "native:build": "cd desktop/native && npm install && npm run build",
    "native:download": "node desktop/scripts/download-native-helpers.mjs",
    "workspace:create-app": "cd desktop && node scripts/create-workspace-app.mjs",
    "electron:install": "install-electron",
    "electron:dev": "node desktop/scripts/electron-dev-runner.mjs",
    "electron:typecheck": "cd desktop && tsgo -p tsconfig.electron.json --pretty false --noEmit && tsgo -p tsconfig.preload.json --pretty false --noEmit",
    "electron:typecheck:watch": "cd desktop && concurrently -k --kill-others-on-fail \"tsgo -w -p tsconfig.electron.json --preserveWatchOutput --noEmit\" \"tsgo -w -p tsconfig.preload.json --preserveWatchOutput --noEmit\"",
    "electron:build": "bun run native:build && cd desktop && tsgo --build && vite build && tsgo -p tsconfig.electron.json && tsgo -p tsconfig.preload.json && cd .. && electron-builder",
    "electron:preview": "cd desktop && tsgo -p tsconfig.electron.json && tsgo -p tsconfig.preload.json && cd .. && electron .",
    "check:boundary": "node runtime/scripts/check-boundary.mjs",
    "tsc6": "bunx --package typescript@6.0.3 tsc"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1041.0",
    "@convex-dev/better-auth": "^0.12.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@effect/opentelemetry": "4.0.0-beta.57",
    "@effect/platform-node": "4.0.0-beta.57",
    "@google/genai": "^1.51.0",
    "@legendapp/list": "3.0.0-beta.44",
    "@mistralai/mistralai": "^2.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@react-three/fiber": "^9.6.1",
    "@sinclair/typebox": "0.34.49",
    "@smithy/node-http-handler": "^4.6.1",
    "@smithy/types": "^4.14.1",
    "@stripe/react-stripe-js": "6.3.0",
    "@stripe/stripe-js": "9.4.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.167.32",
    "ai": "^6.0.174",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-auth": "1.6.9",
    "cloudflared": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.37.0",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "dugite": "3.2.2",
    "effect": "4.0.0-beta.59",
    "esbuild": "^0.28.0",
    "gaxios": "^7.1.4",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "googleapis-common": "^8.0.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "openai": "6.35.0",
    "partial-json": "^0.1.7",
    "picomatch": "^4.0.4",
    "proxy-agent": "^8.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.8.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "three": "^0.184.0",
    "uiohook-napi": "^1.5.5",
    "undici": "^8.2.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.13",
    "concurrently": "^9.2.1",
    "electron": "42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tar": "^7.5.13",
    "tw-animate-css": "^1.4.0",
    "@typescript/native-preview": "^7.0.0-dev.20260508.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "8.0.11",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "axios": "^1.13.5",
    "cross-spawn": "^7.0.6",
    "qs": "^6.15.0",
    "tar": "^7.5.10",
    "vite": "8.0.11"
  },
  "optionalDependencies": {
    "mac-screen-capture-permissions": "^2.1.0"
  },
  "build": {
    "appId": "com.stella.app",
    "productName": "Stella",
    "protocols": {
      "name": "Stella Auth",
      "schemes": [
        "Stella"
      ]
    },
    "directories": {
      "output": "desktop/release",
      "buildResources": "desktop/build"
    },
    "files": [
      "desktop/dist/**/*",
      "desktop/dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "desktop/resources/audio",
        "to": "audio",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "desktop/native/out",
        "to": "native/out",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "state",
        "to": "state",
        "filter": [
          "DREAM.md",
          "registry.md",
          "skills/**",
          "outputs/README.md"
        ]
      },
      {
        "from": "runtime/extensions",
        "to": "runtime/extensions",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "desktop/build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "desktop/build/icon.icns",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Stella uses your microphone for voice conversations."
      }
    },
    "linux": {
      "target": "AppImage",
      "icon": "desktop/build/icon.png"
    }
  },
  "trustedDependencies": [
    "better-sqlite3",
    "cloudflared",
    "dugite",
    "electron",
    "electron-winstaller",
    "esbuild",
    "mac-screen-capture-permissions",
    "msgpackr-extract",
    "protobufjs",
    "sharp",
    "uiohook-napi"
  ]
}
