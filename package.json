{
  "name": "stella",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "desktop/dist-electron/desktop/electron/main.js",
  "scripts": {
    "dev": "cd desktop && vite",
    "preview": "cd desktop && vite preview",
    "build": "cd desktop && bunx --package typescript@5.9.3 tsc --build && vite build",
    "format": "bunx prettier@3.6.2 --write .",
    "format:check": "bunx prettier@3.6.2 --check .",
    "lint": "cd desktop && eslint .",
    "test": "cd desktop && vitest",
    "test:run": "cd desktop && vitest run",
    "test:electron": "cd desktop && vitest run --config vitest.electron.config.ts",
    "test:stella-browser": "cd desktop && vitest run --config stella-browser/vitest.config.ts",
    "reset": "cd desktop && node scripts/reset-dev.mjs",
    "reset:all": "cd desktop && node scripts/reset-dev.mjs --with-permissions",
    "reset:sql": "cd desktop && node scripts/reset-sql.mjs",
    "native:build": "cd desktop/native && npm install && npm run build",
    "workspace:create-app": "cd desktop && node scripts/create-workspace-app.mjs",
    "electron:dev": "node desktop/scripts/electron-dev-runner.mjs",
    "electron:typecheck": "cd desktop && bunx --package typescript@5.9.3 tsc -p tsconfig.electron.json --pretty false --noEmit && bunx --package typescript@5.9.3 tsc -p tsconfig.preload.json --pretty false --noEmit",
    "electron:typecheck:watch": "cd desktop && concurrently -k --kill-others-on-fail \"bunx --package typescript@5.9.3 tsc -w -p tsconfig.electron.json --preserveWatchOutput --noEmit\" \"bunx --package typescript@5.9.3 tsc -w -p tsconfig.preload.json --preserveWatchOutput --noEmit\"",
    "electron:build": "bun run native:build && cd desktop && bunx --package typescript@5.9.3 tsc --build && vite build && bunx --package typescript@5.9.3 tsc -p tsconfig.electron.json && bunx --package typescript@5.9.3 tsc -p tsconfig.preload.json && cd .. && electron-builder",
    "electron:preview": "cd desktop && bunx --package typescript@5.9.3 tsc -p tsconfig.electron.json && bunx --package typescript@5.9.3 tsc -p tsconfig.preload.json && cd .. && electron .",
    "morph:test": "cd desktop && node scripts/trigger-morph.mjs",
    "emoji-sprite:gen": "cd desktop && bun run scripts/generate-emoji-sprite.ts",
    "check:boundary": "node runtime/scripts/check-boundary.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1004.0",
    "@convex-dev/better-auth": "^0.10.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@google/genai": "^1.44.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@react-three/fiber": "^9.6.1",
    "@sinclair/typebox": "0.34.41",
    "@smithy/node-http-handler": "^4.0.0",
    "@smithy/types": "^4.0.0",
    "@stripe/react-stripe-js": "5.6.1",
    "@stripe/stripe-js": "8.11.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.167.22",
    "ai": "^6.0.116",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "better-auth": "1.4.9",
    "cloudflared": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.33.1",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "dugite": "3.2.1",
    "esbuild": "^0.28.0",
    "gaxios": "^6.7.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^146.0.0",
    "googleapis-common": "^7.2.0",
    "lucide-react": "^0.563.0",
    "morphdom": "^2.7.8",
    "motion": "^12.35.0",
    "openai": "6.26.0",
    "partial-json": "^0.1.7",
    "picomatch": "^4.0.2",
    "proxy-agent": "^6.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.75.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.8.1",
    "streamdown": "^2.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "three": "^0.184.0",
    "uiohook-napi": "^1.5.4",
    "undici": "^7.19.1",
    "ws": "^8.19.0",
    "yaml": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/picomatch": "^4.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.0",
    "bun-types": "^1.3.11",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "tar": "^7.5.10",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.0.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "axios": "^1.13.5",
    "cross-spawn": "^7.0.6",
    "qs": "^6.15.0",
    "tar": "^7.5.10"
  },
  "optionalDependencies": {
    "mac-screen-capture-permissions": "^2.1.0"
  },
  "build": {
    "appId": "com.stella.app",
    "productName": "Stella",
    "protocols": {
      "name": "Stella Auth",
      "schemes": [
        "Stella"
      ]
    },
    "directories": {
      "output": "desktop/release",
      "buildResources": "desktop/build"
    },
    "files": [
      "desktop/dist/**/*",
      "desktop/dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "desktop/resources/audio",
        "to": "audio",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "desktop/native/out",
        "to": "native/out",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "state",
        "to": "state",
        "filter": [
          "DREAM.md",
          "registry.md",
          "skills/**",
          "outputs/README.md"
        ]
      },
      {
        "from": "runtime/extensions",
        "to": "runtime/extensions",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "desktop/build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "desktop/build/icon.icns",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Stella uses your microphone for voice conversations."
      }
    },
    "linux": {
      "target": "AppImage",
      "icon": "desktop/build/icon.png"
    }
  },
  "trustedDependencies": [
    "better-sqlite3",
    "cloudflared",
    "dugite",
    "electron",
    "electron-winstaller",
    "esbuild",
    "mac-screen-capture-permissions",
    "msgpackr-extract",
    "protobufjs",
    "sharp",
    "uiohook-napi"
  ]
}
