.{{ID}}-app {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 4vw, 3rem);
  box-sizing: border-box;
  color: var(--foreground);
  font-family: var(--font-family-sans, "Manrope", sans-serif);
  letter-spacing: var(--font-family-sans--default-letter-spacing, -0.02em);
  overflow: auto;
}

.{{ID}}-hero {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin-bottom: 1.75rem;
}

.{{ID}}-title {
  margin: 0;
  font-family: var(--font-family-display, "Cormorant Garamond", Georgia, serif);
  font-size: clamp(2.4rem, 4vw, 3rem);
  font-weight: 300;
  line-height: 1;
  letter-spacing: -0.04em;
}

.{{ID}}-title em {
  font-style: italic;
  font-weight: 300;
}

.{{ID}}-lead {
  margin: 0;
  max-width: 60ch;
  color: color-mix(in oklch, var(--foreground) 70%, transparent);
  font-size: 13px;
  line-height: 1.5;
  letter-spacing: -0.01em;
}

.{{ID}}-body {
  flex: 1;
  min-height: 0;
}
