.{{ID}}-app {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 16px;
  width: 100%;
  height: 100%;
  padding: 24px;
  box-sizing: border-box;
  font-family: var(--font-family-sans, "Manrope", sans-serif);
  letter-spacing: var(--font-family-sans--default-letter-spacing, -0.02em);
  color: var(--foreground);
  overflow: auto;
}

.{{ID}}-title {
  margin: 0;
  font-size: 18px;
  font-weight: 600;
}

.{{ID}}-subtitle {
  margin: 0;
  font-size: 12px;
  color: var(--text-weaker, var(--muted-foreground));
}
